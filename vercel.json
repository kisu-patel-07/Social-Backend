{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "crons": [{ "path": "/api/cron/refresh-tokens", "schedule": "0 3 * * *" }],
  "functions": {
    "api/index.ts": { "maxDuration": 30 },
    "api/cron/refresh-tokens.ts": { "maxDuration": 60 }
  }
}
